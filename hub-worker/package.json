{
  "name": "arcanum-hub-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute arcanum-hub --local --file=./src/schema.sql",
    "db:init:remote": "wrangler d1 execute arcanum-hub --remote --file=./src/schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.100.0"
  }
}
